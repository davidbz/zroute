{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug zroute",
            "program": "${workspaceFolder}/zig-out/bin/zroute",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "zig build"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug zroute (with args)",
            "program": "${workspaceFolder}/zig-out/bin/zroute",
            "args": ["${input:programArgs}"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "zig build"
        }
    ],
    "inputs": [
        {
            "id": "programArgs",
            "type": "promptString",
            "description": "Program arguments"
        }
    ]
}
