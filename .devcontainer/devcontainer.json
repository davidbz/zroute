{
  "name": "zroute",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ziglang.vscode-zig",
        "ms-vscode.cpptools"
      ]
    }
  },
  "postCreateCommand": "zig version",
  "remoteUser": "vscode",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--cap-add=SYS_ADMIN"
  ],
  "containerEnv": {
    "ZIG_DEBUGGER": "lldb"
  }
}