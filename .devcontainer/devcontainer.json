{
  "name": "zroute",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ziglang.vscode-zig",
        "vadimcn.vscode-lldb"
      ]
    }
  },
  "mounts": [
    "source=zroute-zig-cache,target=${containerWorkspaceFolder}/.zig-cache,type=volume"
  ],
  "postCreateCommand": "zig version && zig build check",
  "remoteUser": "vscode",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--cap-add=SYS_ADMIN"
  ],
  "containerEnv": {
    "ZIG_DEBUGGER": "lldb"
  }
}
